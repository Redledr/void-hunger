; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Void Hunger"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"
config/run/main_scene="res://scenes/main/Main.tscn"

[autoload]

GameState="res://scripts/autoloads/GameState.gd"
EventBus="res://scripts/autoloads/EventBus.gd"
UpgradeManager="res://scripts/autoloads/UpgradeManager.gd"

[rendering]

renderer/rendering_method="compatibility"
