[gd_resource user_type=PackedScene format=3]

# =====---------------------------------------------------------------------
# GameWorld.tscn - The Game Arena
# =====---------------------------------------------------------------------
# This scene contains everything for the round:
#   - Black hole (center of screen)
#   - Asteroid spawner (spawns orbiting objects)
#   - Round timer
# =====---------------------------------------------------------------------

[node name="GameWorld" type="Node2D" instance=true]
parent = "Node2D:2"

# =====---------------------------------------------------------------------
# Background - Dark space background
# =====---------------------------------------------------------------------
[node name="Background" type="ColorRect" instance=true]
parent = "GameWorld:1"
offset_left = 0.0
offset_top = 0.0
offset_right = 0.0
offset_bottom = 0.0
# Deep space black color
color = Color(0.02, 0.02, 0.03, 1)

# =====---------------------------------------------------------------------
# Black Hole - The central object that grows
# =====---------------------------------------------------------------------
[node name="BlackHole" type="ColorRect" instance=true]
parent = "GameWorld:1"
# Centered on screen
offset_left = 0.0
offset_top = 0.0
offset_right = 0.0
offset_bottom = 0.0

[node name="StageLabel" type="Label" instance=true]
parent = "BlackHole:1"
offset_left = 0.0
offset_top = -32.0
offset_bottom = 32.0
text = "Stage 1"
/custom_style_override/
font_size = 24
font_color = Color(1, 1, 1, 0.9)
horizontal_alignment = 1
vertical_alignment = 1

[node name="MassLabel" type="Label" instance=true]
parent = "BlackHole:1"
offset_left = 0.0
offset_top = -8.0
offset_bottom = 8.0
text = "Mass: %d"
/custom_style_override/
font_size = 14
font_color = Color(1, 1, 1, 0.6)
horizontal_alignment = 1
vertical_alignment = 1

# =====---------------------------------------------------------------------
# Spawner - Spawns asteroids during rounds
# =====---------------------------------------------------------------------
[node name="Spawner" type="Node2D" instance=true]
parent = "GameWorld:1"

[node name="Timer" type="Timer" instance=true]
parent = "Spawner:1"
# 30 seconds per round (hardcoded for Phase 1)
wait_time = 30.0
one_shot = true

[node name="CenterMarker" type="Marker2D" instance=true]
parent = "Spawner:1"
position = Vector2(0, 0)
# Inactive by default, can be shown when debugging
#visible = false

# =====---------------------------------------------------------------------
# Asteroid Container - Holds currently active asteroids
# =====---------------------------------------------------------------------
[node name="Asteroids" type="Node2D" instance=true]
parent = "GameWorld:1"

[node name="Asteroid1" type="ColorRect" instance=true]
parent = "Asteroids:1"
offset_left = 0.0
offset_top = 0.0
offset_right = 0.0
offset_bottom = 0.0
# Gray asteroid color
color = Color(0.3, 0.3, 0.35, 1)
# Placeholder size (will be moved by orbit logic)
custom_minimum_size = Vector2(60, 60)

[node name="AsteroidHealthBar" type="ProgressBar" instance=true]
parent = "Asteroid1:1"
offset_left = 0.0
offset_top = 0.0
offset_right = 0.0
offset_bottom = 0.0
max_value = 30.0
# Health bar (red when damaged)
color = Color(0.4, 0.1, 0.1, 1)
/progress/
ratio = 1.0

# =====---------------------------------------------------------------------
# Node Names (for connecting from Main.gd or other scenes)
# =====---------------------------------------------------------------------
# game_world.get_node("BlackHole")
# game_world.get_node("Spawner/Timer")
# game_world.get_node("Asteroids/Asteroid1")
# =====---------------------------------------------------------------------
